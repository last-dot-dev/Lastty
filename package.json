{
  "name": "lastty",
  "private": true,
  "version": "0.1.7",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "tauri": "tauri",
    "bench:renderers": "cargo run -p lastty --release --bin bench_renderers -- --iterations 30 --out /tmp/lastty-renderer-bench.json",
    "bench:xterm": "./scripts/run-xterm-bench.sh",
    "bench:xterm:verify-failure": "node ./scripts/verify-xterm-bench-failure.mjs",
    "bench:xterm:summary": "node ./scripts/summarize-xterm-bench.mjs /tmp/lastty-xterm-bench.json",
    "bench:trace": "node ./scripts/summarize-perf-trace.mjs /tmp/lastty-perf.jsonl",
    "bench:stress": "./scripts/run-stress-bench.sh",
    "bench:stress:summary": "node ./scripts/stress/summarize-stress.mjs /tmp/lastty-stress.json",
    "bump-version": "node ./scripts/bump-version.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^29.0.2",
    "typescript": "^5.7",
    "vite": "^6",
    "vitest": "^3.2.4"
  }
}
