{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Lastty",
  "version": "0.1.22",
  "identifier": "com.last.lastty",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && node scripts/prepare-sidecars.mjs"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lastty",
        "width": 1200,
        "height": 800,
        "decorations": true,
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/lastty-mcp"],
    "category": "DeveloperTool",
    "shortDescription": "Agent-native tiled terminal for codemaxxing",
    "longDescription": "Lastty is an agent-native tiled terminal. Run coding agents in PTY panes with structured UI updates, built for orchestrating parallel AI workflows.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "providerShortName": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/last-dot-dev/Lastty/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdBNjVCQkY0QkU2NDFGClJXUWZaTDcwdTJWNkFJdFhZYS90WlVCdFNvT1RDYVFVUSs2M2FxTW55eXYycnh5WFk2KzFTL0ZxCg==",
      "dialog": false
    }
  }
}
